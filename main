-- Utility: Bildirim Sistemi
local function Notify(msg)
    task.spawn(function()
        local n = Instance.new("TextLabel", sg)
        n.Size = UDim2.new(0, 220, 0, 40)
        n.Position = UDim2.new(1, 20, 0.9, 0)
        n.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
        n.Text = "  " .. msg
        n.TextColor3 = Color3.fromRGB(150, 0, 255) -- Titan Moru
        n.Font = Enum.Font.GothamBold
        n.TextSize = 12
        n.TextXAlignment = Enum.TextXAlignment.Left
        Instance.new("UICorner", n).CornerRadius = UDim.new(0, 8)
        Instance.new("UIStroke", n).Color = Color3.fromRGB(100, 0, 200)
        
        n:TweenPosition(UDim2.new(1, -240, 0.9, 0), "Out", "Back", 0.5)
        task.wait(2)
        n:TweenPosition(UDim2.new(1, 20, 0.9, 0), "In", "Back", 0.5)
        task.wait(0.5)
        n:Destroy()
    end)
end

-- Bypass Item Fonksiyonu
local function RequestItemMax(itemName)
    task.spawn(function()
        local candidates = {"GetItem", "Getİtem", "Get_Item", "GetTool", "1Too1l", "GiveItem"}
        if RE then
            for _, rName in ipairs(candidates) do
                local r = RE:FindFirstChild(rName)
                if r then
                    pcall(function()
                        if r:IsA("RemoteFunction") then r:InvokeServer("PickingTools", itemName)
                        else r:FireServer("PickingTools", itemName) end
                    end)
                end
            end
        end
        local trg = RE:FindFirstChild("1Playe1rTrigge1rEven1t") or RE:FindFirstChild("AcceptedToolToServer")
        if trg then pcall(function() trg:FireServer("AcceptedToolToServer", itemName) end) end
    end)
end

