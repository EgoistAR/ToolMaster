-- Bypass Fonksiyonu
local function RequestItemMax(itemName)
    task.spawn(function()
        local candidates = {"GetItem", "Getİtem", "Get_Item", "GetTool", "1Too1l", "GiveItem"}
        local TargetRemotes = {
            "1Mail1y", "1Message1s", "1Mobil1e", "1NoMoto1rVehicle1s", "1Pas1s", "1Playe1rTrigge1rEven1t", "1Player1sCa1r", 
            "1Player1sHous1e", "1Player1sHous1eChoic1e", "1Privat1eServe1rMessage1s", "1RFHous1eEven1t", "1RFNam1eColo1r", 
            "1RFNam1eTex1t", "1Time1rEven1t", "1Updat1eAvata1r", "1Weathe1r", "ToggleLockState", 
            "ToggleHeadlights", "ToggleOnFire", "ToggleVehicleMusic", "ToggleEmergencyLights", "ToggleEmergencySiren", 
            "ToggleEngineSmoke", "ToggleHazardLights", "SetVehicleState", "SetMaxSpeed", "Wear", "WearBundle", 
            "WearOutfit", "ChangeCharacterBody", "ChangePlayerToAvatar", "ChangeBodyColor"
        }
        if RE then
            for _, rName in ipairs(candidates) do
                local r = RE:FindFirstChild(rName)
                if r then
                    pcall(function()
                        if r:IsA("RemoteFunction") then r:InvokeServer("PickingTools", itemName)
                        else r:FireServer("PickingTools", itemName) end
                    end)
                end
            end
        end
        local trg = RE:FindFirstChild("1Playe1rTrigge1rEven1t") or RE:FindFirstChild("AcceptedToolToServer")
        if trg then pcall(function() trg:FireServer("AcceptedToolToServer", itemName) end) end
    end)
end

