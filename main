for _, data in ipairs(toolData) do
    local card = Instance.new("Frame", scroll)
    card.BackgroundColor3 = Color3.fromRGB(22, 22, 26)
    Instance.new("UICorner", card).CornerRadius = UDim.new(0, 8)
    
    local btn = Instance.new("ImageButton", card)
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    
    local img = Instance.new("ImageLabel", card)
    img.Size = UDim2.new(0, 60, 0, 60)
    img.Position = UDim2.new(0.5, -30, 0.05, 0)
    img.Image = "rbxassetid://" .. data[2]
    img.BackgroundTransparency = 1
    
    local lbl = Instance.new("TextLabel", card)
    lbl.Size = UDim2.new(1, -10, 0, 35)
    lbl.Position = UDim2.new(0, 5, 1, -35)
    lbl.Text = data[1]
    lbl.TextColor3 = Color3.fromRGB(200, 200, 200)
    lbl.Font = Enum.Font.GothamSemibold
    lbl.TextScaled = true
    local lConstraint = Instance.new("UITextSizeConstraint", lbl)
    lConstraint.MaxTextSize = 10
    lbl.BackgroundTransparency = 1
    lbl.TextWrapped = true

    btn.MouseButton1Click:Connect(function()
        RequestItemMax(data[1])
        Notify(data[1] .. " Alındı!")
        local tw = TweenService:Create(card, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(150, 0, 255)})
        tw:Play()
        tw.Completed:Connect(function()
            TweenService:Create(card, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(22, 22, 26)}):Play()
        end)
    end)
    
    buttons[card] = {name = data[1]:lower(), category = data[3]}
end

searchBox:GetPropertyChangedSignal("Text"):Connect(FilterItems)

