-- Fonksiyonlar ve Değişkenler
local buttons = {}
local currentCategory = "All"

local function FilterItems()
    local t = searchBox.Text:lower()
    for card, info in pairs(buttons) do
        local nameMatch = t == "" or info.name:find(t)
        local catMatch = currentCategory == "All" or info.category == currentCategory
        card.Visible = nameMatch and catMatch
    end
    scroll.CanvasPosition = Vector2.new(0,0)
end

-- Kategorileri Oluşturma
local categories = {"All", "Weapons", "Pets", "Food", "Baby", "Tools", "Misc"}
for _, cat in ipairs(categories) do
    local cBtn = Instance.new("TextButton", catFrame)
    cBtn.Size = UDim2.new(0, 80, 1, -10)
    cBtn.BackgroundColor3 = cat == "All" and Color3.fromRGB(150, 0, 255) or Color3.fromRGB(30, 30, 35)
    cBtn.Text = cat
    cBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    cBtn.Font = Enum.Font.GothamBold
    cBtn.TextSize = 11
    Instance.new("UICorner", cBtn).CornerRadius = UDim.new(0, 6)
    
    cBtn.MouseButton1Click:Connect(function()
        currentCategory = cat
        for _, btn in ipairs(catFrame:GetChildren()) do
            if btn:IsA("TextButton") then
                TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(30, 30, 35)}):Play()
            end
        end
        TweenService:Create(cBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(150, 0, 255)}):Play()
        FilterItems()
    end)
end

